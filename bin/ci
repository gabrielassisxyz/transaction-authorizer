#!/usr/bin/env bash
# The single deterministic gate: format, lint, tests, coverage. CI runs exactly this
# script, so a green local run means a green pipeline.
set -euo pipefail
cd "$(dirname "$0")/.."

if command -v gitleaks >/dev/null 2>&1; then
    gitleaks detect --source . --no-banner
else
    echo "warning: gitleaks is not installed; the secret scan ran only in CI" >&2
fi

./gradlew --console=plain ktlintCheck detekt test koverVerify

# Last, so a prose hit still lets the compiler and the tests report first.
bin/slop-guard
